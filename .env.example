# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=change-me

DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# Your public URL, used in confirmation emails and CSRF checks
SITE_URL=https://comoney.example.com

# Comma-separated list of domains the app is served from
ALLOWED_HOSTS=comoney.example.com

# Must include your SITE_URL scheme+host for Django's CSRF middleware
CSRF_TRUSTED_ORIGINS=https://comoney.example.com

# ── Optional ──────────────────────────────────────────────────────────────────
DB_NAME=comoney
DB_USER=comoney

# Set to TRUE to allow new users to register
ENABLE_REGISTRATION=

# Port to expose on the host (default 8000)
PORT=8000

# Gunicorn worker count — rule of thumb: 2 × CPU cores + 1
GUNICORN_WORKERS=2

# ── Email (required for registration confirmation and password reset) ──────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=TRUE
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=noreply@example.com
