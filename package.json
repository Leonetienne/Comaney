{
  "name": "comaney",
  "private": true,
  "scripts": {
    "build:css": "sass build/scss/main.scss static/dist/main.css --style=compressed --no-source-map",
    "build:js": "esbuild build/js/expenses.js --bundle --minify --target=es2020 --outfile=static/dist/expenses.js",
    "build:dashboard": "esbuild build/js/dashboard.js --bundle --minify --target=es2020 --outfile=static/dist/dashboard.js",
    "build:buddy_expense": "esbuild build/js/buddy_expense.js --bundle --minify --target=es2020 --outfile=static/dist/buddy_expense.js",
    "build:project_charts": "esbuild build/js/project_charts.js --bundle --minify --target=es2020 --outfile=static/dist/project_charts.js",
    "build:project_detail": "esbuild build/js/project_detail.js --bundle --minify --target=es2020 --outfile=static/dist/project_detail.js",
    "build": "npm run build:css && npm run build:js && npm run build:dashboard && npm run build:buddy_expense && npm run build:project_charts && npm run build:project_detail",
    "watch:css": "sass --watch build/scss/main.scss:static/dist/main.css"
  },
  "dependencies": {
    "alpinejs": "^3.14.9",
    "chart.js": "^4.4.0",
    "codemirror": "^6.0.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/theme-one-dark": "^6.1.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.4",
    "sass": "^1.77.6"
  }
}
